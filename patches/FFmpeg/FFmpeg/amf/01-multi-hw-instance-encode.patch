Add multi-VCN split-frame encoding support to AMF HEVC and AV1 encoders

diff --git a/libavcodec/amfenc.h b/libavcodec/amfenc.h
index ff5ce0b..798b1f5 100644
--- a/libavcodec/amfenc.h
+++ b/libavcodec/amfenc.h
@@ -120,6 +120,9 @@ typedef struct AMFEncoderContext {
     /* enum AMF_VIDEO_ENCODER_AV1_AQ_MODE_ENUM */
     int                 aq_mode;
 
+    // Multi-VCN split-frame encoding (dual VCN instances)
+    int                 multi_hw_instance;
+
     // Preanalysis - specific options
 
     int                 preanalysis;
diff --git a/libavcodec/amfenc_av1.c b/libavcodec/amfenc_av1.c
index 70642a6..5c44c78 100644
--- a/libavcodec/amfenc_av1.c
+++ b/libavcodec/amfenc_av1.c
@@ -138,6 +138,8 @@ static const AVOption options[] = {
 
     { "smart_access_video",     "Enable Smart Access Video to enhance  performance by utilizing both APU and dGPU memory access",                OFFSET(smart_access_video),             AV_OPT_TYPE_BOOL, {.i64 = -1  }, -1, 1, VE},
 
+    { "multi_hw_instance",      "Enable split-frame encoding across multiple VCN hardware instances",   OFFSET(multi_hw_instance),   AV_OPT_TYPE_BOOL, {.i64 = -1 }, -1, 1, VE },
+
     //Pre Analysis options
     { "preanalysis",                            "Enable preanalysis",                                           OFFSET(preanalysis),                            AV_OPT_TYPE_BOOL,   {.i64 = -1 }, -1, 1, VE },
 
@@ -342,6 +344,11 @@ static av_cold int amf_encode_init_av1(AVCodecContext* avctx)
         }
     }
 
+    if (ctx->multi_hw_instance != -1) {
+        AMF_ASSIGN_PROPERTY_BOOL(res, ctx->encoder, AMF_VIDEO_ENCODER_AV1_MULTI_HW_INSTANCE_ENCODE, ctx->multi_hw_instance != 0);
+        av_log(avctx, AV_LOG_INFO, "Multi-VCN split-frame encode: %s\n", ctx->multi_hw_instance ? "enabled" : "disabled");
+    }
+
     // Pre-Pass, Pre-Analysis, Two-Pass
     if (ctx->rate_control_mode == AMF_VIDEO_ENCODER_AV1_RATE_CONTROL_METHOD_CONSTANT_QP) {
         AMF_ASSIGN_PROPERTY_INT64(res, ctx->encoder, AMF_VIDEO_ENCODER_AV1_RATE_CONTROL_PREENCODE, 0);
diff --git a/libavcodec/amfenc_hevc.c b/libavcodec/amfenc_hevc.c
index fe1d948..9dfc95d 100644
--- a/libavcodec/amfenc_hevc.c
+++ b/libavcodec/amfenc_hevc.c
@@ -111,6 +111,8 @@ static const AVOption options[] = {
 
     { "smart_access_video",     "Enable Smart Access Video to enhance  performance by utilizing both APU and dGPU memory access",        OFFSET(smart_access_video), AV_OPT_TYPE_BOOL, {.i64 = -1  }, -1, 1, VE},
 
+    { "multi_hw_instance",      "Enable split-frame encoding across multiple VCN hardware instances",   OFFSET(multi_hw_instance),   AV_OPT_TYPE_BOOL, {.i64 = -1 }, -1, 1, VE },
+
     //Pre Analysis options
     { "preanalysis",                            "Enable preanalysis", OFFSET(preanalysis),                            AV_OPT_TYPE_BOOL,   {.i64 = -1 }, -1, 1, VE },
 
@@ -321,6 +323,11 @@ static av_cold int amf_encode_init_hevc(AVCodecContext *avctx)
         }
     }
 
+    if (ctx->multi_hw_instance != -1) {
+        AMF_ASSIGN_PROPERTY_BOOL(res, ctx->encoder, AMF_VIDEO_ENCODER_HEVC_MULTI_HW_INSTANCE_ENCODE, ctx->multi_hw_instance != 0);
+        av_log(avctx, AV_LOG_INFO, "Multi-VCN split-frame encode: %s\n", ctx->multi_hw_instance ? "enabled" : "disabled");
+    }
+
     // Pre-Pass, Pre-Analysis, Two-Pass
     if (ctx->rate_control_mode == AMF_VIDEO_ENCODER_HEVC_RATE_CONTROL_METHOD_CONSTANT_QP) {
         AMF_ASSIGN_PROPERTY_INT64(res, ctx->encoder, AMF_VIDEO_ENCODER_HEVC_PREENCODE_ENABLE, 0);
